NODE_ENV=development
PORT=3000

# CORS: origins permitidos (vírgula para múltiplos)
CORS_ORIGIN=http://localhost:5500

# JWT
JWT_SECRET=change_me_super_secret_minimum_32_chars_required
JWT_ISSUER=pitch-futebol
JWT_AUDIENCE=pitch-futebol-api

# Prefixo das rotas de admin (mude para obscurecer — nunca use /admin)
ADMIN_ROUTE_PREFIX=/manage

# Token de ownership para IDOR
OWNERSHIP_TOKEN_SECRET=change_me_ownership_secret_32chars

# CPF pepper
CPF_PEPPER=change_me_cpf_pepper

# Admin fixo (hash bcrypt da senha)
ADMIN_USER=admin
ADMIN_PASS_HASH=replace_with_bcrypt_hash

# ─── MySQL ────────────────────────────────────────────────────────────────────
# Use APENAS UM dos três blocos abaixo, dependendo do ambiente.
#
# OPÇÃO 1 — Railway, via connection string (recomendado em produção):
#   No serviço da API, no painel do Railway, adicione a variável:
#     MYSQL_URL=${{MySQL.MYSQL_URL}}
#   (isso referencia automaticamente a URL do plugin MySQL linkado ao projeto)
# MYSQL_URL=mysql://user:password@host:3306/database
#
# OPÇÃO 2 — Railway, variáveis nativas do plugin MySQL (alternativa à OPÇÃO 1):
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
#
# OPÇÃO 3 — Local / docker-compose:
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pitch_futebol
DB_USER=pitch
DB_PASSWORD=pitchpass
#
# DB_SSL: força ligar/desligar TLS na conexão MySQL.
# Por padrão, SSL liga automaticamente sempre que o host não é
# localhost/127.0.0.1/db/mysql (ou seja, liga sozinho no Railway).
# DB_SSL=true

# Upload de imagens (pasta fora do webroot)
# Padrão: <raiz do projeto>/uploads
UPLOAD_DIR=./uploads
